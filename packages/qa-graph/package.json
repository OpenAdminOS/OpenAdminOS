{
  "name": "@openagents/qa-graph",
  "version": "0.1.0-dev",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "openagents-qa-graph": "./dist/cli.js"
  },
  "scripts": {

{
  "name": "@openadminos/qa-graph",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "openadminos-qa-graph": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build -w @openadminos/agent-sdk && tsc -p tsconfig.json",
    "typecheck": "npm run build -w @openadminos/agent-sdk && tsc -p tsconfig.json --noEmit",
    "qa": "npm run build && node ./dist/cli.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@openadminos/agent-sdk": "0.1.9",
    "ajv": "^8.17.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3"
  }
}

{
  "name": "@openagents/runtime",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build -w @openagents/agent-sdk && tsc -p tsconfig.json",
    "typecheck": "npm run build -w @openagents/agent-sdk && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.1",
    "@openagents/agent-sdk": "0.1.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}

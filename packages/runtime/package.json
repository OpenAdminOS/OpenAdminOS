{
  "name": "@openadminos/runtime",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build -w @openadminos/agent-sdk && npm run build -w @openadminos/connector-teams && tsc -p tsconfig.json",
    "typecheck": "npm run build -w @openadminos/agent-sdk && npm run build -w @openadminos/connector-teams && tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.1",
    "@openadminos/agent-sdk": "0.1.9",
    "@openadminos/connector-teams": "0.1.9",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}

{
  "name": "@openadminos/desktop",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "npm run build:packages && npm run build:electron && concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dev:renderer": "vite",
    "build": "npm run build:packages && tsc -b && npm run build:electron && vite build",
    "build:packages": "npm run build -w @openadminos/agent-sdk && npm run build -w @openadminos/runtime",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "typecheck": "npm run build:packages && tsc -b --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@openadminos/agent-sdk": "0.1.8",
    "@openadminos/runtime": "0.1.8",
    "electron-updater": "^6.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.openadminos.desktop",
    "productName": "OpenAdminOS",
    "electronVersion": "42.1.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../agents",
        "to": "agents"
      },
      {
        "from": "../../stats",
        "to": "stats"
      },
      {
        "from": "electron/assets/graph-index",
        "to": "graph-index"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "OpenAdminOS",
        "repo": "OpenAdminOS"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ]
    },
    "dmg": {
      "title": "OpenAdminOS",
      "background": "build/background.tiff",
      "icon": "build/icon.png",
      "iconSize": 128,
      "window": {
        "width": 660,
        "height": 440
      },
      "contents": [
        {
          "x": 170,
          "y": 230,
          "type": "file"
        },
        {
          "x": 490,
          "y": 230,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        { "target": "appx", "arch": ["x64"] }
      ]
    },
    "appx": {
      "applicationId": "OpenAdminOS",
      "displayName": "OpenAdminOS",
      "identityName": "OpenAdminOS.OpenAdminOS.OpenAdminOS",
      "publisher": "CN=E5B1EEE1-CB55-4BCF-9214-2A6446BB2580",
      "publisherDisplayName": "OpenAdminOS",
      "languages": ["en-US"],
      "showNameOnTiles": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
